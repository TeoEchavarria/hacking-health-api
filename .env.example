# =============================================================================
# Hacking Health API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# API Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# =============================================================================
# Database Configuration (MongoDB)
# =============================================================================
MONGO_URI=mongodb://localhost:27017
MONGO_DB=hacking_health

# =============================================================================
# Security & JWT
# =============================================================================
# Generate secret key with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OAuth Configuration (Social Login)
# =============================================================================

# Google OAuth
# Get your credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID (Type: Android)
# 2. Add your app's package name and SHA-1 signing certificate
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# GitHub OAuth (optional - for future use)
# Get your credentials from: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# =============================================================================
# OpenAI Configuration
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-vision-preview

# =============================================================================
# AWS S3 Configuration (Optional - for file storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your_s3_bucket_name

# =============================================================================
# Firebase Cloud Messaging (Optional)
# =============================================================================
FCM_PROJECT_ID=

# =============================================================================
# Error Tracking (Optional)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=["*"]
# For specific origins: CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]
